#!/usr/bin/env bash
set -Eeuo pipefail

umask 077

require_var() {
  local name="$1"

  if [[ -z "${!name:-}" ]]; then
    echo "Missing required environment variable: ${name}" >&2
    exit 2
  fi
}

require_var BACKUP_DIR

BACKUP_NAME_PREFIX="${BACKUP_NAME_PREFIX:-dz_saas_commerce}"
BACKUP_RETENTION_DAYS="${BACKUP_RETENTION_DAYS:-30}"
COMPOSE_PROJECT_DIR="${COMPOSE_PROJECT_DIR:-/opt/mayfair/deploy/staging}"
COMPOSE_ENV_FILE="${COMPOSE_ENV_FILE:-images.env}"
COMPOSE_FILE_1="${COMPOSE_FILE_1:-docker-compose.staging.example.yml}"
COMPOSE_FILE_2="${COMPOSE_FILE_2:-docker-compose.staging.ephemeral.yml}"
POSTGRES_SERVICE="${POSTGRES_SERVICE:-postgres}"

TIMESTAMP="$(date -u +%Y%m%dT%H%M%SZ)"
BACKUP_NAME="${BACKUP_NAME_PREFIX}_${TIMESTAMP}.dump"
BACKUP_PATH="${BACKUP_DIR}/${BACKUP_NAME}"
TMP_PATH="${BACKUP_PATH}.tmp"
TMP_LIST_PATH="${TMP_PATH}.list"

mkdir -p "$BACKUP_DIR"

if [[ ! -d "$COMPOSE_PROJECT_DIR" ]]; then
  echo "Compose project directory does not exist: ${COMPOSE_PROJECT_DIR}" >&2
  exit 2
fi

if [[ ! -f "$COMPOSE_PROJECT_DIR/$COMPOSE_ENV_FILE" ]]; then
  echo "Compose env file does not exist: ${COMPOSE_PROJECT_DIR}/${COMPOSE_ENV_FILE}" >&2
  exit 2
fi

if [[ ! -f "$COMPOSE_PROJECT_DIR/$COMPOSE_FILE_1" ]]; then
  echo "Compose file does not exist: ${COMPOSE_PROJECT_DIR}/${COMPOSE_FILE_1}" >&2
  exit 2
fi

if [[ ! -f "$COMPOSE_PROJECT_DIR/$COMPOSE_FILE_2" ]]; then
  echo "Compose file does not exist: ${COMPOSE_PROJECT_DIR}/${COMPOSE_FILE_2}" >&2
  exit 2
fi

COMPOSE_ENV_FILE_PATH="${COMPOSE_PROJECT_DIR}/${COMPOSE_ENV_FILE}"
COMPOSE_FILE_1_PATH="${COMPOSE_PROJECT_DIR}/${COMPOSE_FILE_1}"
COMPOSE_FILE_2_PATH="${COMPOSE_PROJECT_DIR}/${COMPOSE_FILE_2}"

cleanup() {
  rm -f "$TMP_PATH" "$TMP_LIST_PATH"
}

trap cleanup EXIT

# Create PostgreSQL custom-format dump using docker compose exec inside the postgres container.
# POSTGRES_USER and POSTGRES_DB are sourced from the postgres container environment.
docker compose \
  --env-file "$COMPOSE_ENV_FILE_PATH" \
  -f "$COMPOSE_FILE_1_PATH" \
  -f "$COMPOSE_FILE_2_PATH" \
  --project-directory "$COMPOSE_PROJECT_DIR" \
  exec -T "$POSTGRES_SERVICE" sh -lc \
    'pg_dump \
      --format=custom \
      --verbose \
      --no-owner \
      --no-acl \
      --dbname="$POSTGRES_DB" \
      --username="$POSTGRES_USER"' \
  > "$TMP_PATH"

test -s "$TMP_PATH"

# Generate restore listing using pg_restore inside the postgres container.
docker compose \
  --env-file "$COMPOSE_ENV_FILE_PATH" \
  -f "$COMPOSE_FILE_1_PATH" \
  -f "$COMPOSE_FILE_2_PATH" \
  --project-directory "$COMPOSE_PROJECT_DIR" \
  exec -T "$POSTGRES_SERVICE" sh -lc \
    'pg_restore --list' \
  < "$TMP_PATH" \
  > "$TMP_LIST_PATH"

mv "$TMP_PATH" "$BACKUP_PATH"
mv "$TMP_LIST_PATH" "${BACKUP_PATH}.list"

# Generate SHA256 checksum on the host.
(
  cd "$BACKUP_DIR"
  sha256sum "$BACKUP_NAME" > "${BACKUP_NAME}.sha256"
)

# Cleanup old backup files based on retention days.
find "$BACKUP_DIR" -type f -name "${BACKUP_NAME_PREFIX}_*.dump" -mtime +"$BACKUP_RETENTION_DAYS" -print -delete
find "$BACKUP_DIR" -type f -name "${BACKUP_NAME_PREFIX}_*.dump.list" -mtime +"$BACKUP_RETENTION_DAYS" -print -delete
find "$BACKUP_DIR" -type f -name "${BACKUP_NAME_PREFIX}_*.dump.sha256" -mtime +"$BACKUP_RETENTION_DAYS" -print -delete

echo "PostgreSQL staging backup created: ${BACKUP_PATH}"
