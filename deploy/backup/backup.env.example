# Copy to an external secure path such as /etc/dz-saas-commerce/backup.env.
# Do not commit real production secrets.

BACKUP_DIR=/secure/backups/dz-saas-commerce/postgres
BACKUP_NAME_PREFIX=dz_saas_commerce
BACKUP_RETENTION_DAYS=30

# Prefer DATABASE_URL from the secret manager when available.
DATABASE_URL=

# Fallback when DATABASE_URL is not used.
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Object storage backup target.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_ENDPOINT=
AWS_BUCKET=
BACKUP_BUCKET=
BACKUP_PREFIX=dz-saas-commerce/object-storage

# Staging restore drill safeguards.
# Restore drills must target a temporary database, never the live staging database.
BACKUP_FILE=
ALLOW_STAGING_RESTORE=false

# Administrative connection used only to CREATE/DROP the temporary drill database.
# Example shape: postgres://USER:PASSWORD@HOST:5432/postgres
STAGING_ADMIN_DATABASE_URL=

# Temporary restore database name. Must start with dz_saas_restore_drill_.
RESTORE_DRILL_DATABASE=dz_saas_restore_drill_YYYYMMDD_HHMMSS

# Full connection URL to the temporary restore database above.
# Example shape: postgres://USER:PASSWORD@HOST:5432/dz_saas_restore_drill_YYYYMMDD_HHMMSS
RESTORE_DRILL_DATABASE_URL=

# Cleanup is disabled by default and requires exact confirmation.
CLEANUP_RESTORE_DRILL_DATABASE=false
CONFIRM_DROP_RESTORE_DRILL_DATABASE=
