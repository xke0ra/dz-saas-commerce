BACKEND_IMAGE=ghcr.io/owner/repo/backend:sha-replace_me
STOREFRONT_IMAGE=ghcr.io/owner/repo/storefront:sha-replace_me
BACKEND_ENV_FILE=./backend.env
STOREFRONT_ENV_FILE=./storefront.env
# Bind the internal Nginx edge locally when an external TLS proxy such as Caddy
# terminates public 80/443 on the same host.
EDGE_PORT=127.0.0.1:8080
