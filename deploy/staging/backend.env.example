APP_NAME="DZ SaaS Commerce"
APP_ENV=staging
APP_KEY=base64:replace_with_staging_key
APP_DEBUG=false
APP_URL=https://api.staging.example.com
ASSET_URL=https://api.staging.example.com
TRUSTED_PROXIES=172.16.0.0/12

APP_LOCALE=ar
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=replace_with_staging_postgres_host
DB_PORT=5432
DB_DATABASE=replace_with_staging_database
DB_USERNAME=replace_with_staging_user
DB_PASSWORD=replace_with_staging_password
DB_SSLMODE=require

BROADCAST_CONNECTION=log
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=.staging.example.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

FILESYSTEM_DISK=s3
PRODUCT_IMAGES_DISK=s3

SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
SCOUT_PREFIX=staging_
MEILISEARCH_HOST=replace_with_staging_meilisearch_url
MEILISEARCH_KEY=replace_with_staging_meilisearch_key

REDIS_CLIENT=phpredis
REDIS_HOST=replace_with_staging_redis_host
REDIS_PASSWORD=replace_with_staging_redis_password
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=replace_with_staging_smtp_host
MAIL_PORT=587
MAIL_USERNAME=replace_with_staging_smtp_user
MAIL_PASSWORD=replace_with_staging_smtp_password
MAIL_FROM_ADDRESS=no-reply@staging.example.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=replace_with_staging_access_key
AWS_SECRET_ACCESS_KEY=replace_with_staging_secret_key
AWS_DEFAULT_REGION=replace_with_staging_region
AWS_BUCKET=replace_with_staging_bucket
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
